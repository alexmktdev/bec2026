# Logs
logs
logs.txt
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies & build output
node_modules
dist
dist-ssr
*.local

# Salida de build de Cloud Functions (se regenera con `npm run build` / predeploy de Firebase)
functions/lib

# Vite
.vite

# TypeScript — caché incremental si en el futuro se emite fuera de node_modules
*.tsbuildinfo

# Tests / cobertura (por si agregas Vitest u otro runner)
coverage
*.lcov

# Cachés de linters / bundlers
.eslintcache
.parcel-cache

# Sentry / analizadores (suelen generarse localmente; .sentryclirc puede llevar token)
.sentryclirc
sentry.properties
bundle-stats.html
stats.html

# Windows
Thumbs.db
Desktop.ini
ehthumbs.db

# Android / iOS (por si el repo crece; google-services.json suele ir en apps nativas)
google-services.json
GoogleService-Info.plist

# --- Secretos y entorno (no subir al repo) ---
# Raíz del frontend: .env.example SÍ se versiona como plantilla.
.env
.env.*
!.env.example

# Cloud Functions: .env locales o archivos de runtime con API keys / secrets
functions/.env
functions/.env.*
!functions/.env.example
functions/.runtimeconfig.json

# Firebase Admin / Google Cloud — claves privadas (nunca en Git)
serviceAccountKey.json
*-firebase-adminsdk-*.json
*-service-account*.json
credentials.json
gcloud-application-credentials.json

# Caché y logs de emuladores / CLI Firebase (pueden incluir rutas o datos de depuración)
.firebase
firebase-debug.log
firestore-debug.log
ui-debug.log

# Vercel — enlace de proyecto; puede asociarse a tokens en el entorno local
.vercel

# Certificados y claves privadas
*.pem
*.p12
*.pfx

# direnv / otros cargadores de env locales
.envrc


# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
