rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: get the user's role from /users/{uid}
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperadmin() {
      return isAuthenticated() && getUserRole() == 'superadmin';
    }

    function isRevisorOrAdmin() {
      return isAuthenticated() && getUserRole() in ['superadmin', 'revisor', 'admin'];
    }

    // Historical RUTs: public can check a specific RUT, but cannot list all
    match /historical_ruts/{rutId} {
      allow get: if true;
      allow list: if isRevisorOrAdmin();
      allow write: if isSuperadmin();
    }

    // Postulantes: lectura/escritura solo vía Cloud Function (Admin SDK). Sin acceso directo desde el cliente.
    match /postulantes/{postId} {
      allow create, get, list, update, delete: if false;
    }

    // Cola Trigger Email (colección por defecto de la extensión). Si usas otra en TRIGGER_EMAIL_COLLECTION,
    // añade aquí un bloque match equivalente con el mismo nombre de colección.
    match /mail/{mailId} {
      allow read, write: if false;
    }

    // Users/roles: each user can only read their own doc; superadmin can read all; only superadmin can write
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperadmin());
      allow write: if isSuperadmin();
    }

    // Config del filtro de revisión de documentación
    match /config/filtro_revision_doc {
      allow read, write: if isRevisorOrAdmin();
    }

    // Config del criterio de desempate
    match /config/filtro_desempate {
      allow read, write: if isRevisorOrAdmin();
    }

    // Tokens de descarga ZIP (solo Cloud Functions / Admin SDK)
    match /descarga_docs_zip_tokens/{tokenId} {
      allow read, write: if false;
    }

    // Lotes de enlaces del export Excel (solo Admin SDK; un doc por export, no por fila)
    match /excel_zip_export_batches/{batchId} {
      allow read, write: if false;
    }

    // Tabla de revisión de documentos importada desde Excel (mismo usuario que escribe; revisor/admin/superadmin)
    match /excel_revision_imports/{userId} {
      allow read, delete: if isRevisorOrAdmin() && request.auth.uid == userId;
      allow create, update: if isRevisorOrAdmin() && request.auth.uid == userId
        && request.resource.data.keys().hasAll([
          'headers',
          'sheetName',
          'coincideConPlantillaExport',
          'rowCount',
          'chunkCount',
          'updatedAt',
        ])
        && request.resource.data.headers is list
        && request.resource.data.sheetName is string
        && request.resource.data.coincideConPlantillaExport is bool
        && request.resource.data.rowCount is int
        && request.resource.data.chunkCount is int
        && request.resource.data.updatedAt is timestamp;
    }

    match /excel_revision_imports/{userId}/chunks/{chunkId} {
      allow read, delete: if isRevisorOrAdmin() && request.auth.uid == userId;
      allow create, update: if isRevisorOrAdmin() && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['rows'])
        && request.resource.data.rows is list;
    }
  }
}
