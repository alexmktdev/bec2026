# Copia a `functions/.env` (no subir a Git). Firebase CLI carga `.env` en Functions v2.
# Mantén este archivo solo como plantilla sin datos reales.

# Cola de correo propia (Cloud Function + SMTP)

# Encolar documentos en la cola de correo cuando se registra un rechazo de entrada.
ENABLE_RECHAZO_ENTRADA_EMAIL_QUEUE=true

# Encolar correo de confirmación cuando crearPostulacion registra al postulante (misma cola mail + SMTP).
# En producción también existe el parámetro Firebase del mismo nombre (default true si no lo configuras).
# Pon false aquí o en la consola para desactivar.
ENABLE_POSTULACION_EXITOSA_EMAIL_QUEUE=true

# Colección de cola (por defecto: mail).
MAIL_QUEUE_COLLECTION=mail

# Opcional: remitente por mensaje.
# MAIL_FROM_NAME=Nombre Institucional
# MAIL_FROM_EMAIL=notificaciones@tu-dominio.cl

# SMTP: definir en Firebase Secret Manager (no en este archivo):
# SMTP_HOST
# SMTP_PORT
# SMTP_USER
# SMTP_PASS

# Opcional fallback para `from` cuando el documento no lo trae:
# SMTP_FROM_EMAIL=notificaciones@tu-dominio.cl

# Logo institucional para el correo (URL pública)
# MAIL_LOGO_URL=https://tu-dominio.cl/logo.png
