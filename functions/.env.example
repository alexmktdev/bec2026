# Copia a `functions/.env` (no subir a Git). Firebase CLI carga `.env` al desplegar Functions v2.
# Documentación: https://firebase.google.com/docs/functions/config-env
#
# Emulador local: con `firebase emulators:start --only functions`, el runtime define FUNCTIONS_EMULATOR=true
# y las callables no exigen App Check (ver httpsCallableDefaults.ts). Útil para depurar correos/callables desde Vite.

# Opcional: orígenes CORS para callables (separados por coma). Si está vacío, se usa la lista en allowedWebOrigins.ts
# ALLOWED_WEB_ORIGINS=https://tu-dominio.cl,http://localhost:5173

# =============================================================================
# Cola de correo propia (Cloud Function + Nodemailer) — sin extensión
# =============================================================================
# registrarPostulanteRechazadoEntrada encola documentos en Firestore (colección `mail`)
# y `processMailQueue` los envía por SMTP.

# Encolar documentos en la cola de correo cuando se registra un rechazo de entrada.
ENABLE_RECHAZO_ENTRADA_EMAIL_QUEUE=true

# Colección de cola (por defecto: mail).
MAIL_QUEUE_COLLECTION=mail

# Opcional: remitente por mensaje.
# MAIL_FROM_NAME=Beca Municipal de Molina 2026
# MAIL_FROM_EMAIL=tu.cuenta@gmail.com

# Compatibilidad temporal (variables antiguas):
# ENABLE_TRIGGER_EMAIL_RECHAZO_ENTRADA
# TRIGGER_EMAIL_COLLECTION
# TRIGGER_EMAIL_FROM_NAME
# TRIGGER_EMAIL_FROM_EMAIL

# SMTP (se recomienda definir como secretos en Firebase, no en .env):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=tu.cuenta@gmail.com
#   SMTP_PASS=tu_app_password
# Opcional fallback para `from` cuando el documento no lo trae:
#   SMTP_FROM_EMAIL=tu.cuenta@gmail.com
# Logo institucional para cabecera del correo (URL pública):
#   MAIL_LOGO_URL=https://tu-dominio.cl/logo-molina.png
# Opcional: si no defines MAIL_LOGO_URL, se intenta usar:
#   PUBLIC_APP_URL=https://tu-dominio.cl
# y se arma /src/assets/logo-molina.png
