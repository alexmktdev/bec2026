{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "../src/postulacion/shared/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "../src/postulacion/shared/**/*.ts",
    "../src/types/postulante.ts"
  ]
}