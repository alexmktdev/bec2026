VITE_FIREBASE_API_KEY=tu-api-key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# Obligatorio en Vercel (Production): sin esto App Check devuelve 400 "Invalid App ID"
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Región de Cloud Functions (mismo valor que functions/src/index.ts → setGlobalOptions)
# Ejemplos: southamerica-west1 | southamerica-east1 | us-central1
VITE_FUNCTIONS_REGION=southamerica-west1

# Opcional: URLs de funciones HTTP de descarga ZIP (si no coinciden con el patrón projectId + región)
# VITE_DESCARGA_ZIP_HTTP_BASE=https://southamerica-west1-TU_PROYECTO.cloudfunctions.net/descargarZipDocumentosPostulanteHttp
# VITE_DESCARGA_ZIP_COMPLETA_HTTP_BASE=https://southamerica-west1-TU_PROYECTO.cloudfunctions.net/descargarZipDocumentacionCompletaHttp

# App Check — site key de la app Web (obligatoria si usas enforceAppCheck en Functions)
# Firebase → App Check → registrar app: si dice reCAPTCHA v3 → deja USE_ENTERPRISE en false
# Si el asistente usó reCAPTCHA Enterprise → VITE_APPCHECK_USE_ENTERPRISE=true
VITE_RECAPTCHA_SITE_KEY=tu-recaptcha-site-key
VITE_APPCHECK_USE_ENTERPRISE=false

# Solo desarrollo: token de depuración (Console → App Check → tu app → ⋮ → Manage debug tokens)
# Vacío = la primera carga imprime un token en la consola del navegador para copiar y registrar ahí.
# VITE_APPCHECK_DEBUG_TOKEN=

# Desarrollo sin App Check: apunta las callables al emulador (`npm run serve` en functions/ o `firebase emulators:start --only functions`).
# En el emulador, enforceAppCheck queda desactivado; producción no cambia.
# VITE_USE_FUNCTIONS_EMULATOR=true
# VITE_FUNCTIONS_EMULATOR_HOST=127.0.0.1
# VITE_FUNCTIONS_EMULATOR_PORT=5001
